{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "matchengine-raft",
            "program": "${workspaceFolder}/target/debug/matchengine-raft",
            "args": ["--id", "1", "--http-addr", "127.0.0.1:21001" ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "debug",
                "RUST_BACKTRACE=1": "1"
            }
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in library 'matchengine-raft'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=matchengine-raft"
                ],
                "filter": {
                    "name": "matchengine-raft",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'matchengine-raft'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=matchengine-raft",
                    "--package=matchengine-raft"
                ],
                "filter": {
                    "name": "matchengine-raft",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'matchengine-raft'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=matchengine-raft",
                    "--package=matchengine-raft"
                ],
                "filter": {
                    "name": "matchengine-raft",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug integration test 'cluster'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--test=cluster",
                    "--package=matchengine-raft"
                ],
                "filter": {
                    "name": "cluster",
                    "kind": "test"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}